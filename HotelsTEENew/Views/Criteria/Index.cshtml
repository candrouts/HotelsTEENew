<script>
    (function () {
        function steps() {
            return [
                { sel: "#guide-features", title: "Χαρακτηριστικά & Παροχές Καταλύματος", text: "Ξεκινήστε εδώ: δηλώστε με «Ναι/Όχι» τις βασικές παροχές του καταλύματός σας (π.χ. πισίνα, κήπος, κουζίνα). Όσα κριτήρια δεν αφορούν το κατάλυμά σας απενεργοποιούνται αυτόματα και δεν μετρούν στη βαθμολογία. Μπορείτε να συμπτύξετε την κάρτα μετά τη συμπλήρωση." },
                { sel: "#guide-bar", title: "Η βαθμολογία σας", text: "Η μπάρα δείχνει τη συνολική (αναγμένη) βαθμολογία 0–95 και το μετάλιο που επιτυγχάνετε. Ενημερώνεται ζωντανά καθώς συμπληρώνετε κριτήρια." },
                { sel: "#guide-demote", title: "Υποβιβασμός βαθμίδας", text: "Η συνολική σας βαθμολογία αντιστοιχεί σε ανώτερο μετάλιο, αλλά υπολείπεστε στις ελάχιστες βάσεις ενός ή περισσότερων πυλώνων — εδώ φαίνεται ποιοι." },
                { sel: "#guide-nexttier", title: "Επόμενη βαθμίδα", text: "Πόσοι πόντοι συνολικής βαθμολογίας λείπουν για το επόμενο μετάλιο." },
                { sel: "#guide-pillars", title: "Πυλώνες", text: "Κάθε κουμπί δείχνει «αρχική βαθμολογία → αναγωγή» στις μονάδες του πυλώνα. Το πράσινο ✓ ή κόκκινο 🔒 δείχνει αν καλύπτετε την ελάχιστη βάση του πυλώνα για το μετάλιο-στόχο." },
                { sel: ".guide-subpillars", title: "Υποπυλώνες", text: "Εδώ αναλύονται οι υποπυλώνες. Η μπάρα προόδου και η βαθμολογία δείχνουν πόσα κριτήρια έχετε ολοκληρώσει." },
                { sel: ".guide-crit-tabs", title: "Καρτέλες κριτηρίου", text: "Κάθε κριτήριο έχει: «Επιλογή» (η απάντησή σας), «Παραδείγματα Πρακτικής Εφαρμογής» (καθοδήγηση) και «Τεκμήρια» (μεταφόρτωση υποστηρικτικών αρχείων). Το «More» στη μεθοδολογία εμφανίζει πλήρη επεξήγηση." },
                { sel: "#guide-actions", title: "Αποθήκευση & Υποβολή", text: "«Προσωρινή Αποθήκευση»: αποθηκεύει χωρίς οριστικοποίηση. «Υποβολή»: οριστική — εμφανίζει το μετάλιο που θα λάβετε και δεν αλλάζει μετά." }
            ];
        }
        document.addEventListener("DOMContentLoaded", function () {
            if (window.PageGuide) PageGuide.register("guide_seen_criteria", "#guide-pillars .nav-item", steps);
        });
    })();
</script>
