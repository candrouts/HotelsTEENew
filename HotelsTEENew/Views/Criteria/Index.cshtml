                                                    <div data-bind="html: description " style="font-size:12px;"></div>

                                                    <!-- end file preview template -->
                                                    <br /><br />
                                                    <!--  /ko -->

                                                </div>
                                                <!-- /ko -->

                                            </div> <!-- end tab-content-->

                                        </div> <!-- end card-body-->
                                    </div> <!-- end card-->
                                </div>

                                <!-- /ko  -->




                            </div>
                            <!-- /ko  -->

                        </div> <!-- end tab-content-->
                    </div> <!-- end col-->
                </div>
                <!-- end row-->



            </div>
            <!-- /ko  -->
        </div>

    </div>
</div>


