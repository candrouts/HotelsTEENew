<script>
    (function () {
        function steps() {
            return [
                { sel: "#guide-features", title: "Χαρακτηριστικά & Παροχές Καταλύματος", text: "Εδώ βλέπετε τις παροχές όπως τις δήλωσε ο ξενοδόχος (π.χ. πισίνα, κήπος). Κατά την αυτοψία μπορείτε να τις επιβεβαιώσετε ή να τις διορθώσετε με «Ναι/Όχι» — τα σχετικά κριτήρια απενεργοποιούνται/ενεργοποιούνται αυτόματα και προσαρμόζεται η βαθμολογία." },
                { sel: "#guide-bar", title: "Βαθμολογία καταλύματος", text: "Η μπάρα δείχνει τη συνολική (αναγμένη) βαθμολογία 0–95 και το μετάλιο που επιτυγχάνει το κατάλυμα, ζωντανά καθώς αξιολογείτε." },
                { sel: "#guide-demote", title: "Υποβιβασμός βαθμίδας", text: "Η συνολική βαθμολογία αντιστοιχεί σε ανώτερο μετάλιο, αλλά το κατάλυμα υπολείπεται στις ελάχιστες βάσεις ενός ή περισσότερων πυλώνων." },
                { sel: "#guide-nexttier", title: "Επόμενη βαθμίδα", text: "Πόσοι πόντοι συνολικής βαθμολογίας λείπουν για το επόμενο μετάλιο." },
                { sel: "#guide-pillars", title: "Πυλώνες", text: "«Αρχική βαθμολογία → αναγωγή» στις μονάδες του πυλώνα. Το πράσινο ✓ ή κόκκινο 🔒 δείχνει αν καλύπτεται η ελάχιστη βάση του πυλώνα για το μετάλιο-στόχο." },
                { sel: ".guide-subpillars", title: "Υποπυλώνες", text: "Ανάλυση των υποπυλώνων, με την πρόοδο και τη βαθμολογία τους." },
                { sel: ".guide-crit-tabs", title: "Καρτέλες κριτηρίου", text: "Κάθε κριτήριο έχει: «Επιλογή» (η αξιολόγησή σας), «Παραδείγματα Πρακτικής Εφαρμογής» (καθοδήγηση) και «Τεκμήρια» (υποστηρικτικά αρχεία). Το «More» στη μεθοδολογία εμφανίζει πλήρη επεξήγηση." },
                { sel: "#guide-actions", title: "Υποβολή τελικής κατάταξης", text: "Με την «Υποβολή» οριστικοποιείται η τελική κατάταξη και εμφανίζεται το μετάλιο που θα λάβει το κατάλυμα." }
            ];
        }
        document.addEventListener("DOMContentLoaded", function () {
            if (window.PageGuide) PageGuide.register("guide_seen_viewcert", "#guide-pillars .nav-item", steps);
        });
    })();
</script>

