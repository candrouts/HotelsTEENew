@model decimal

@{
    ViewBag.Title = "ViewCertificate";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<input type="hidden" id="model" value="@Model" />
<input type="hidden" id="mode" value="@ViewBag.Mode" />
<input type="hidden" id="ro" value="@((ViewBag.ReadOnly == true) ? "1" : "0")" />

<!-- Static loader: ορατός από το πρώτο render (πριν φορτώσουν τα scripts),
     κρύβεται από το JS όταν ολοκληρωθεί η φόρτωση των δεδομένων -->
<div id="page-loader" style="position:fixed; inset:0; background:rgba(255,255,255,0.85); z-index:3000; display:flex; align-items:center; justify-content:center;">
    <div class="text-center">
        <div class="spinner-border avatar-lg text-primary" role="status"></div>
        <h5 class="mt-3">Φόρτωση δεδομένων αξιολόγησης...</h5>
        <p class="text-muted mb-0"><small>Η πρώτη φόρτωση ενδέχεται να διαρκέσει λίγο περισσότερο,<br />καθώς προετοιμάζονται τα κριτήρια της αξιολόγησης.</small></p>
    </div>
</div>

@{
    int _mode = (int)ViewBag.Mode;
    bool _readOnly = ViewBag.ReadOnly == true;
    string _pageTitle = _mode == 1 ? "Αυτοαξιολόγηση Ξενοδόχου (Προβολή)"
                      : _mode == 3 ? "Τελική Κατάταξη"
                      : "Αυτοψία Καταλύματος";
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="/Certificate">Αιτήσεις</a></li>
                    <li class="breadcrumb-item active">@_pageTitle</li>
                </ol>
            </div>
            <h4 class="page-title">
                @_pageTitle
                @if (_readOnly)
                {
                    <span class="badge bg-secondary ms-1">Μόνο ανάγνωση</span>
                }
                <span class="ms-3" style="font-weight:normal;">
                    <a class="text-muted" data-bs-toggle="collapse" href="#page-legend" role="button" style="font-size:12px;">
                        <i class="mdi mdi-help-circle text-info me-1" style="font-size:15px;vertical-align:-2px;"></i>Επεξήγηση σελίδας
                    </a><span id="page-guide-slot"></span>
                </span>
            </h4>
        </div>
    </div>
</div>




<div class="row">

    <!-- ════ Κάρτα: Χαρακτηριστικά & Παροχές Καταλύματος (έλεγχος επιθεωρητή) ════ -->
    <!-- ko if: hasFeatures -->
    <div class="col-12">
        <div id="guide-features" class="border card border-info mb-2" style="background-color:#eef6fc;">
            <div class="card-header py-2 d-flex justify-content-between align-items-center" style="background-color:rgba(57,175,209,0.12);">
                <h5 class="card-title mb-0">
                    <i class="uil uil-building me-1 text-info"></i> Χαρακτηριστικά &amp; Παροχές Καταλύματος
                    <!-- ko if: disabledByFeaturesCount() > 0 -->
                    <span class="badge bg-secondary ms-1" data-bind="text: disabledByFeaturesCount() + ' κριτήρια ανενεργά'"></span>
                    <!-- /ko -->
                </h5>
                <a href="javascript:void(0)" class="text-muted" data-bind="click: function(){ featuresCollapsed(!featuresCollapsed()); }">
                    <span data-bind="text: featuresCollapsed() ? 'Επεξεργασία ▾' : 'Σύμπτυξη ▴'"></span>
                </a>
            </div>
            <div class="card-body py-2" data-bind="visible: !featuresCollapsed()">
                <p class="text-muted mb-2" style="font-size:13px;">
                    Οι παροχές όπως δηλώθηκαν από τον ξενοδόχο. <!-- ko if: enableAll -->Επιβεβαιώστε ή διορθώστε τις κατά την αυτοψία — τα σχετικά κριτήρια απενεργοποιούνται αυτόματα.<!-- /ko -->
                </p>
                <div data-bind="foreach: features">
                    <div class="d-flex align-items-center justify-content-between py-1 border-bottom">
                        <div class="flex-grow-1 pe-2">
                            <strong>
                                <!-- ko if: icon --><i data-bind="attr: { class: icon }" class="me-1"></i><!-- /ko -->
                                <span data-bind="text: title"></span>
                            </strong>
                            <!-- ko if: description -->
                            <br /><small class="text-muted" data-bind="text: description"></small>
                            <!-- /ko -->
                        </div>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn"
                                    data-bind="click: function(){ $root.setFeature($data, true); },
                                               css: { 'btn-success': answered() && hasFeature() === true, 'btn-outline-secondary': !(answered() && hasFeature() === true) },
                                               enable: $root.enableAll()">Ναι</button>
                            <button type="button" class="btn"
                                    data-bind="click: function(){ $root.setFeature($data, false); },
                                               css: { 'btn-danger': answered() && hasFeature() === false, 'btn-outline-secondary': !(answered() && hasFeature() === false) },
                                               enable: $root.enableAll()">Όχι</button>
                        </div>
                    </div>
                </div>
            </div>
            <!-- ko if: featuresCollapsed() -->
            <div class="card-body py-2">
                <div data-bind="foreach: features" style="display:inline;">
                    <span class="badge me-1 mb-1"
                          data-bind="text: title + (answered() ? (hasFeature() ? ': Ναι' : ': Όχι') : ': —'),
                                     css: { 'bg-success': answered() && hasFeature() === true, 'bg-secondary': answered() && hasFeature() === false, 'bg-light text-dark': !answered() }"></span>
                </div>
            </div>
            <!-- /ko -->
        </div>
    </div>
    <!-- /ko -->

    <div id="guide-bar" class="sticky-wrap tier-wrap col-xl-12">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
            <div>
                <strong data-bind="text: tierLabel"></strong>
                <span class="text-muted">(<span data-bind="text: totalScore"></span>/95)</span>
                <!-- ko if: isDemoted() -->
                <span id="guide-demote" class="badge bg-warning ms-1"><i class="uil uil-lock-alt"></i> <span data-bind="text: gatingMessage"></span></span>
                <!-- /ko -->
            </div>
            <span id="guide-nexttier" class="badge" data-bind="text: nextTierDeltaText, css: nextTierBadgeClass"></span>
        </div>

        <div class="tier-bar">
            <div class="tier-bands"></div>
            <div class="tier-fill" data-bind="style: { width: progressPct }"></div>
            <div class="tier-needle" data-bind="style: { left: progressPct }"></div>
        </div>

        <div class="tier-scale">
            <span style="left:0%">0</span>
            <span style="left:17.79%">15</span>
            <span style="left:36.84%">35</span>
            <span style="left:57.89%">55</span>
            <span style="left:78.94%">75</span>
            <span style="left:100%">95</span>
        </div>
        <hr style="margin:0!important" />


        @if (!_readOnly)
        {
        <div id="guide-actions" class="float-end ">
            <!-- ko if: aiEnabled() && !readOnly() -->
            <a class="btn btn-sm btn-soft-info mx-2 mt-1" data-bind="click: generateAiReport, css: { 'disabled': aiReportBusy() }">
                <!-- ko if: aiReportBusy() --><span class="spinner-border spinner-border-sm me-1"></span>Σύνταξη...<!-- /ko -->
                <!-- ko ifnot: aiReportBusy() --><i class="mdi mdi-robot-outline me-1"></i>Σχέδιο Έκθεσης (AI)<!-- /ko -->
            </a>
            <!-- /ko -->
            <a class="btn btn-sm btn-success mx-2 mt-1" data-bind="click: enableAll() ? saveData : null, css: { 'disabled': !enableAll() }"> <i class="uil uil-message me-1"></i>  Υποβολή</a>
        </div>
        <div class="float-end ">
            <a class="btn btn-sm btn-primary mx-2 mt-1" data-bind="click: enableAll() ? saveDataTemp : null, css: { 'disabled': !enableAll() }"><i class="uil uil-save me-1"></i> Προσωρινή Αποθήκευση</a>
        </div>
        }

    </div>

    <!-- ════ Επεξήγηση σελίδας (legend — το toggle link είναι δίπλα στον τίτλο) ════ -->
    <div class="col-12">
        <div class="collapse" id="page-legend">
            <div class="card mb-0 mt-1"><div class="card-body py-2" style="font-size:12px;">
                <div class="row">
                    <div class="col-md-6">
                        <p class="mb-1"><strong>Μπάρα βαθμολογίας:</strong> η συνολική (αναγμένη) βαθμολογία 0–95 και η βαθμίδα/μετάλιο του καταλύματος.</p>
                        <p class="mb-1"><span class="badge bg-warning"><i class="uil uil-lock-alt"></i></span> <strong>Υποβιβασμός:</strong> η συνολική αντιστοιχεί σε ανώτερο μετάλιο, αλλά υπολείπεται σε ελάχιστες βάσεις πυλώνων.</p>
                        <p class="mb-0"><span class="badge bg-light text-dark border">λείπουν Χ βαθμοί</span> πόντοι για την επόμενη βαθμίδα.</p>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1"><strong>Κουμπιά πυλώνων:</strong> «αρχική βαθμολογία → αναγωγή» στις μονάδες του πυλώνα.</p>
                        <p class="mb-1"><span class="badge bg-success"><i class="mdi mdi-check"></i></span> καλύπτει την ελάχιστη βάση &nbsp; <span class="badge bg-danger"><i class="mdi mdi-lock"></i></span> υπολείπεται (δείχνει το ζητούμενο ελάχιστο).</p>
                        <p class="mb-0"><strong>Υποβολή:</strong> οριστικοποιεί την τελική κατάταξη — εμφανίζει το μετάλιο που θα λάβει το κατάλυμα.</p>
                    </div>
                </div>
            </div></div>
        </div>
    </div>

    <div class="col-sm-12">

        <ul id="guide-pillars" class="nav nav-pills bg-nav-pills nav-justified mb-3 tier-wrap">
            <!-- ko foreach: {data: categories, as: 'category'}  -->
            <li class="nav-item">
                <a data-bs-toggle="tab" aria-expanded="false" class="nav-link rounded-0" data-bind="attr: { 'href': '#tab-'+category.id() },css:{ 'active': $index() == 0 }">
                    <i class="mdi mdi-home-variant d-md-none d-block"></i>
                    <span class="d-none d-md-block" data-bind="html:category.title"></span>
                    <p class="inbox-item-date">
                        <button type="button" class="btn btn-sm cr-btn-outline-primary px-1 py-0" data-bs-toggle="tooltip"
                                data-bind="attr: { title: 'Βαθμολογία ' + category.rawPoints() + ' από ' + category.maxGrade() + ' → αναγωγή στις ' + totalUnits() + ' μονάδες του πυλώνα' }">
                            <span data-bind="html: category.rawPoints()"></span>
                            <i class="mdi mdi-arrow-right-thin"></i>
                            <strong data-bind="html: category.totalPoints()"></strong>
                        </button>
                        <!-- ko if: $root.usePillarThresholds() && $root.byTotalTier() && $root.pillarRequired($root.byTotalTier().id, category) > 0 -->
                        <!-- ko if: $root.pillarMeets($root.byTotalTier().id, category) -->
                        <span class="badge bg-success" data-bs-toggle="tooltip"
                              data-bind="attr: { title: 'Καλύπτει την ελάχιστη βάση του πυλώνα για ' + $root.byTotalTier().title + ' (απαιτούνται ' + $root.pillarRequired($root.byTotalTier().id, category).toFixed(1) + ' μόρ., έχει ' + category.totalPoints() + ')' }">
                            <i class="mdi mdi-check"></i>
                        </span>
                        <!-- /ko -->
                        <!-- ko ifnot: $root.pillarMeets($root.byTotalTier().id, category) -->
                        <span class="badge bg-danger" data-bs-toggle="tooltip"
                              data-bind="attr: { title: 'Δεν καλύπτει την ελάχιστη βάση του πυλώνα για ' + $root.byTotalTier().title + ' (απαιτούνται ' + $root.pillarRequired($root.byTotalTier().id, category).toFixed(1) + ' μόρ., έχει ' + category.totalPoints() + ')' }">
                            <i class="mdi mdi-lock"></i> <span data-bind="text: $root.pillarRequired($root.byTotalTier().id, category).toFixed(1)"></span>
                        </span>
                        <!-- /ko -->
                        <!-- /ko -->
                    </p>
                </a>
            </li>
            <!-- /ko  -->

        </ul>

        <div class="tab-content">


            <!-- ko foreach: { data: categories, as: 'category' }  -->
            <div class="tab-pane" data-bind="attr: { 'id': 'tab-'+category.id() }, css:{ 'active show': $index() == 0  }">

                <div class="row">
                    <div id="v-pills-tab" class="col-sm-3 mb-2 mb-sm-0 guide-subpillars" style="border-right: var(--ct-border-width) var(--ct-border-style) var(--ct-border-color) !important;">
                        <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist" aria-orientation="vertical" data-bind="attr:{ 'id': 'pills-tab-'+category.id() }">

                            <!-- ko foreach: { data: category.categories, as: 'subCategory' }  -->
                            <div class="progress " style="height: 5px;">
                                <div class="progress-bar progress-bar-striped bg-danger" role="progressbar"
                                     data-bind="attr:{'id':'subTab-'+subCategory.id(),  'aria-valuenow': Math.round(subCategory.completedCriteria()),  'aria-valuemax': subCategory.totalTrackable(), 'aria-label': remainingText()},style:{ 'width' : subCategory.percentSelectCriteria() + '%' },css:{'bg-danger': percentSelectCriteria() < 50,'bg-warning': percentSelectCriteria() >= 50 && percentSelectCriteria() < 100, 'bg-success': percentSelectCriteria() === 100 }, bsTooltip: remainingText()"></div>
                            </div>
                            <a class="d-flex justify-content-between nav-link shadow-lg p-2 mb-2 rounded" data-bs-toggle="pill" role="tab" aria-selected="true" data-bind="attr:{ 'id':'subTab-'+subCategory.id(),'href':'#subTabPane-'+subCategory.id(),'aria-controls':'subTabPane-'+subCategory.id() },css:{ 'active': $index() == 0 }">

                                <!-- Ρύθμιση για Left panel HELPER -->
                                <span role="button" tabindex="0"
                                      data-bs-toggle="offcanvas"
                                      data-bind="attr: { 'data-bs-target': '#settings-' + subCategory.id() }">
                                    <i class="ri-settings-3-line font-22" data-bs-toggle="tooltip" title="Βοήθεια"></i>
                                </span>

                                <i class="mdi mdi-home-variant d-md-none d-block"></i>
                                <span class="d-none d-md-block" data-bind="html:title"></span>
                                <p class="inbox-item-date">
                                    <button type="button" class="btn btn-sm cr-btn-outline-primary px-1 py-0" data-bs-toggle="tooltip" title="Η βαθμολογία σου / Μέγιστη Βαθμολογία"> <span data-bind="html:subCategory.totalPoints() + ' / ' + subCategory.maxGrade()"></span> </button>
                                </p>
                                @*<span class="badge badge-success-lighten" data-bind="html:subCategory.totalPoints"></span>*@

                            </a>

                            <!-- /ko  -->
                        </div>
                    </div> <!-- end col-->

                    <div class="col-sm-9">
                        <div class="tab-content criteria-scroll" data-bind="attr:{ 'id': 'pills-tabContent-'+category.id() }">

                            <!-- ko foreach: { data: category.categories, as: 'subCategory' }  -->
                            <div class="tab-pane fade" role="tabpanel" data-bind="attr:{ 'id': 'subTabPane-'+subCategory.id(),'aria-labelledby':'subTab-'+subCategory.id() }, css:{ 'active show': $index() == 0  }">


                                <!-- ko foreach : criteria  -->
                                <div class="col-xs-12">
                                    <div class="card " data-bind="@*visible:  expandPEA ,*@ css: { 'criteria-disabled': isDisabled() }" role="group" data-bind-aria-disabled="isDisabled() ? 'true' : 'false'">
                                        <div class="card-body" data-bind="css: {'required': isRequired()}">
                                            <!-- ko if : canShowNotApplicableSwitch() === true && !featureMapped() -->
                                            <div class="float-end form-check form-switch">

                                                <input type="checkbox" class="form-check-input" id="customSwitch1" data-bind="checked:isApplicable, enable: $root.enableAll()">

                                                <label class="form-check-label" for="customSwitch1" data-bind="text: isApplicable() ? '👍 Εφαρμόζεται' : '👉 Επαναφορά', css: { 'text-success': isApplicable, 'text-danger': !isApplicable() }"></label>

                                            </div>

                                            <!-- /ko  -->
                                            <!-- ko if: featureDisabled() -->
                                            <div class="float-end">
                                                <span class="badge badge-secondary-lighten" data-bs-toggle="tooltip"
                                                      data-bind="attr: { title: featureReason }">
                                                    <i class="uil uil-lock-alt me-1"></i><span data-bind="text: featureReason"></span>
                                                </span>
                                            </div>
                                            <!-- /ko -->
                                            <h4>
                                                <span class="badge badge-info-lighten" data-bind="html:code"></span>&nbsp;&nbsp;
                                                <!-- ko if : isRequired() === true -->
                                                <i class="ri-lock-fill text-danger me-1" data-bs-toggle="tooltip" title="Υποχρεωτικό κριτήριο"></i>&nbsp;&nbsp;
                                                <!-- /ko  -->
                                                <span data-bind="html:title"></span>
                                                <span class="badge bg-danger ms-2" data-bind="visible: isDisabled">Μη εφαρμόσιμο</span>
                                                <span class="badge bg-danger ms-2" data-bind="visible: isHeritage">Δεν Αφορά (Δ/Α)</span>
                                            </h4>

                                            @*<p data-bind="html: description"></p>*@
                                            <p class="mb-2">
                                                <!-- ko if : displayedDescription() != "" -->
                                                <b>Μεθοδολογία Εφαρμογής/Ελέγχου : </b>
                                                <span data-bind="html: displayedDescription "></span>
                                                <!-- ko if: canToggle() -->
                                                <a href="#" class="badge badge-success-lighten"
                                                   data-bind="text: isExpanded() ? 'Less' : 'More', click: toggleExpand"></a>
                                                <!-- /ko -->
                                                <!-- /ko -->
                                            </p>

                                            <ul class="nav nav-tabs nav-bordered mb-3 no-scroll-tabs guide-crit-tabs" data-bind="css: { 'pe-none': isDisabled() }">
                                                <li class="nav-item">
                                                    <a data-bs-toggle="tab" aria-expanded="false" class="nav-link active" data-bind="attr:{ 'href': '#crtieria-tab1-'+id() }">
                                                        Επιλογή
                                                    </a>
                                                </li>

                                                <li class="nav-item">
                                                    <a data-bs-toggle="tab" aria-expanded="true" class="nav-link" data-bind="attr:{ 'href': '#crtieria-tab3-'+id() }">
                                                        Παραδείγματα Πρακτικής Εφαρμογής
                                                    </a>
                                                </li>
                                                <!-- ko if : needsFiles() == true -->
                                                <li class="nav-item">
                                                    <a data-bs-toggle="tab" aria-expanded="true" class="nav-link" data-bind="attr:{ 'href': '#crtieria-tab4-'+id() }">
                                                        Τεκμήρια
                                                    </a>
                                                </li>
                                                <!-- /ko -->
                                            </ul> <!-- end nav-->
                                            <div class="tab-content" data-bind="css: { 'pe-none': isDisabled() }, attr:{ 'aria-hidden': isDisabled() ? 'true' : 'false' }">
                                                <div class="tab-pane show active" id="dismissing-alerts-preview" data-bind="attr:{ 'id': 'crtieria-tab1-'+id() }">

                                                    <div class="row">
                                                        <div class="col-md-6">


                                                            <!-- ko if : criteriaType() == 1 || criteriaType() == 3  -->
                                                            @*<input type="checkbox" data-bind="iCheckCheckBox: isChecked" /> &nbsp;&nbsp;Επιλογή<br /><br />*@
                                                            <div style="margin-bottom:10px;">
                                                                <!-- ko if: isRequired() -->
                                                                <input type="checkbox" data-bind="attr:{ 'name':'criteria-'+id(), 'id':'criteria-'+id()+'-yes','value':maxGrade },iCheckCheckBox: isChecked, enable: enabled() && $root.enableAll() == true" /> &nbsp;&nbsp;Ναι
                                                                <!-- /ko -->
                                                                <!-- ko if: !isRequired() -->
                                                                <input type="radio" data-bind="attr:{ 'name':'criteria-'+id(), 'id':'criteria-'+id()+'-yes','value':maxGrade },iCheckRadio: isChecked, enable: enabled() && $root.enableAll() == true" /> &nbsp;&nbsp;Ναι
                                                                <!-- /ko -->
                                                            </div>
                                                            <div>
                                                                <!-- ko if: isRequired() -->
                                                                <input type="checkbox" data-bind="attr:{ 'name':'criteria-'+id(), 'id':'criteria-'+id()+'-no','value':0 },iCheckCheckBox: isNotChecked, enable: enabled() && $root.enableAll() == true && !isRequired()" /> &nbsp;&nbsp;Όχι
                                                                <!-- /ko -->
                                                                <!-- ko if: !isRequired() -->
                                                                <input type="radio" data-bind="attr:{ 'name':'criteria-'+id(), 'id':'criteria-'+id()+'-no','value':0 },iCheckRadio: isNotChecked, enable: enabled() && $root.enableAll() == true && !isRequired()" /> &nbsp;&nbsp;Όχι
                                                                <!-- /ko -->
                                                                <!-- ko if: isRequired() -->
                                                                <span class="ms-2 text-muted small">
                                                                    👉 Υποχρεωτικό κριτήριο δεν επιτρέπεται η επιλογή ΌΧΙ.
                                                                </span>
                                                                <!-- /ko -->
                                                            </div>
                                                            <!-- /ko  -->
                                                            <!-- ko if : criteriaType() == 2  -->
                                                            <label for="example-select" class="form-label">Επιλογή</label>
                                                            @*<select class="form-select" data-bind="options: options,  value: value,
                    optionsText: function(item) { return item;}, optionsValue: function(item) { return item;}
                    , optionsCaption: 'Επιλέξτε'"></select>*@
                                                            <select class="form-select"
                                                                    data-bind="options: options,
                                                                                optionsText: 'text',
                                                                                optionsValue: 'value',
                                                                                value: value,
                                                                                optionsCaption: 'Επιλέξτε', enable: enabled() && $root.enableAll() == true"></select>
                                                            <!-- /ko  -->
                                                        </div>

                                                    </div>

                                                </div>


                                                <div class="tab-pane" data-bind="attr:{ 'id': 'crtieria-tab3-'+id() }">
                                                    <span data-bind="html:notes1"></span>
                                                </div> <!-- end preview code-->
                                                <!-- ko if : needsFiles() == true -->
                                                <div class="tab-pane" data-bind="attr:{ 'id': 'crtieria-tab4-'+id() }">

                                                    <!-- ko foreach : files -->
                                                    <div data-bind="html: title " style="font-size:13px;font-weight:bold;"></div>
                                                    <div data-bind="html: description " style="font-size:12px;"></div>


                                                    @if (!_readOnly)
                                                    {
                                                    <!-- ko if: $root.enableAll() -->
                                                    <form action="@Url.Action("PostFiles","Certificate")" method="post" class="dropzone" data-plugin="dropzone" data-previews-container="#file-previews" data-upload-preview-template="#uploadPreviewTemplate" data-bind="attr:{ 'id': 'file-'+id() },dropzone:{files: files, hotelCriteriaID: $root.hotelCriteriaID(), criteriaFileID: id()}">
                                                        <div class="fallback">
                                                            <input name="file" type="file" />
                                                        </div>

                                                        <input type="hidden" id="criteriaFileID" data-bind="value:id" />
                                                        <input type="hidden" id="hotelCriteriaID" data-bind="value:$root.hotelCriteriaID" />
                                                        <div class="dz-message needsclick">
                                                            <i class="h3 text-muted ri-upload-cloud-2-line"></i>
                                                            <h4>Σύρετε αρχεία εδώ ή πατήστε για ανέβασμα.</h4>
                                                        </div>
                                                    </form>
                                                    <!-- /ko -->
                                                    }

                                                    <!-- Preview -->
                                                    <div class="dropzone-previews mt-3" id="file-previews">
                                                        <!-- ko foreach : uploadedFiles  -->
                                                        <div class="card mt-1 mb-0 shadow-none border">
                                                            <div class="p-2">
                                                                <div class="row align-items-center">
                                                                    <div class="col-auto">
                                                                        <div class="avatar-sm rounded bg-light d-flex align-items-center justify-content-center">
                                                                            <i class="ri-file-text-line font-22 text-muted"></i>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col ps-0">
                                                                        <a target="_blank" class="text-muted fw-bold"
                                                                           data-bind="html: fileName, attr: { href: '/Certificate/GetFile/' + id() }"></a>
                                                                        <p class="mb-0" data-dz-size></p>
                                                                        <!-- ko if: aiVerdict() -->
                                                                        <div class="mt-1">
                                                                            <span data-bind="attr: { class: $root.aiBadgeClass(aiVerdict()) }">
                                                                                <i class="mdi mdi-robot-outline me-1"></i><span data-bind="text: $root.aiBadgeLabel(aiVerdict())"></span>
                                                                            </span>
                                                                            <!-- ko if: aiAnswerVerdict() && aiAnswerVerdict() !== 'na' -->
                                                                            <span class="ms-1" data-bind="attr: { class: $root.aiAnswerBadgeClass(aiAnswerVerdict()) + ' ms-1' }">
                                                                                <i class="mdi mdi-scale-balance me-1"></i><span data-bind="text: $root.aiAnswerBadgeLabel(aiAnswerVerdict())"></span>
                                                                            </span>
                                                                            <!-- /ko -->
                                                                            <br /><small class="text-muted" data-bind="text: aiSummary"></small>
                                                                        </div>
                                                                        <!-- /ko -->
                                                                    </div>
                                                                    <!-- ko if: $root.aiEnabled() && !$root.readOnly() -->
                                                                    <div class="col-auto">
                                                                        <button type="button" class="btn btn-sm btn-soft-info"
                                                                                data-bind="click: $root.runAiCheck, disable: aiChecking()"
                                                                                title="AI προ-έλεγχος τεκμηρίου">
                                                                            <!-- ko if: aiChecking() -->
                                                                            <span class="spinner-border spinner-border-sm me-1"></span>Έλεγχος...
                                                                            <!-- /ko -->
                                                                            <!-- ko ifnot: aiChecking() -->
                                                                            <i class="mdi mdi-robot-outline me-1"></i>AI Έλεγχος
                                                                            <!-- /ko -->
                                                                        </button>
                                                                    </div>
                                                                    <!-- /ko -->
                                                                    @if (!_readOnly)
                                                                    {
                                                                    <!-- ko if: $root.enableAll() -->
                                                                    <div class="col-auto">
                                                                        <!-- Button -->
                                                                        <a href="" class="btn btn-link btn-lg text-muted" data-bind="click: $root.deleteFile">
                                                                            <i class="ri-close-line"></i>
                                                                        </a>
                                                                    </div>
                                                                    <!-- /ko -->
                                                                    }
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <!-- /ko -->

                                                    </div>

                                                    <!-- file preview template -->

                                                    <div class="d-none" id="uploadPreviewTemplate">
                                                        <div class="card mt-1 mb-0 shadow-none border">
                                                            <div class="p-2">
                                                                <div class="row align-items-center">
                                                                    <div class="col-auto">
                                                                        <img data-dz-thumbnail src="#" class="avatar-sm rounded bg-light" alt="">
                                                                    </div>
                                                                    <div class="col ps-0">
                                                                        <a href="javascript:void(0);" class="text-muted fw-bold"></a>
                                                                        <p class="mb-0" data-dz-size></p>
                                                                    </div>
                                                                    <div class="col-auto">
                                                                        <!-- Button -->
                                                                        <a href="" class="btn btn-link btn-lg text-muted" data-dz-remove>
                                                                            <i class="ri-close-line"></i>
                                                                        </a>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <!-- end file preview template -->
                                                    <br /><br />
                                                    <!--  /ko -->

                                                </div>
                                                <!-- /ko -->

                                            </div> <!-- end tab-content-->

                                        </div> <!-- end card-body-->
                                    </div> <!-- end card-->
                                </div>

                                <!-- /ko  -->




                            </div>
                            <!-- /ko  -->

                        </div> <!-- end tab-content-->
                    </div> <!-- end col-->
                </div>
                <!-- end row-->



            </div>
            <!-- /ko  -->
        </div>

    </div>
</div>


