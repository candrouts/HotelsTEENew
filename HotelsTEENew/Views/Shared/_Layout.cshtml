    <script src="~/Scripts/ViewModels/AdminCriteriaViewModel.js"></script>
    <script src="~/Scripts/ViewModels/PendingActionsViewModel.js"></script>


    <script>
        Dropzone.autoDiscover = false;
    </script>


    <script type="text/javascript">



        document.addEventListener('DOMContentLoaded', function () {
            new bootstrap.Tooltip(document.body, {
                selector: '[data-bs-toggle="tooltip"]',
                container: 'body',
                boundary: 'window'
            });
        });

        function showLoader() {
            $("#modal-loader").modal("show")
        }

        function hideLoader() {
            $("#modal-loader").modal("hide")
        }


        $(document).ready(function () {
            //  App.init();
            //showLoader();

        });

        ko.applyBindings(new MenuViewModel(), document.getElementById("leftside-menu-container"));



        var documentView = $("#currentView").val();

        if (documentView == "Criteria/Index") {
            ko.applyBindings(new CriteriaViewModel(), document.getElementById("container"));
            ko.applyBindings(new TopBarViewModel(), document.getElementById("top-bar"));
        }
        else if (documentView == "Certificate/Index") {
            ko.applyBindings(new CertificateViewModel(), document.getElementById("container"));
        }
        else if (documentView == "Certificate/ViewCertificate") {
            ko.applyBindings(new ViewCertificateViewModel(), document.getElementById("container"));
            ko.applyBindings(new TopBarViewModel(), document.getElementById("top-bar"));
        }
        else if (documentView == "InspectorSelection/Index") {
            ko.applyBindings(new InspectorSelectionViewModel(), document.getElementById("container"));
        }
        else if (documentView == "InspectorProfile/Index") {
            ko.applyBindings(new InspectorProfileViewModel(), document.getElementById("container"));
        }
        else if (documentView == "AdminInspectors/Index") {
            ko.applyBindings(new AdminInspectorsViewModel(), document.getElementById("container"));
        }
        else if (documentView == "AdminNotifications/Index") {
            ko.applyBindings(new AdminNotificationsViewModel(), document.getElementById("container"));
        }
        else if (documentView == "AdminMedals/Index") {
            ko.applyBindings(new AdminMedalsViewModel(), document.getElementById("container"));
        }
        else if (documentView == "AdminCertTemplate/Index") {
            ko.applyBindings(new AdminCertTemplateViewModel(), document.getElementById("container"));
        }
        else if (documentView == "AdminFeatures/Index") {
            ko.applyBindings(new AdminFeaturesViewModel(), document.getElementById("container"));
        }
        else if (documentView == "AdminCriteria/Index") {
            ko.applyBindings(new AdminCriteriaViewModel(), document.getElementById("container"));
        }


        function refreshHotelCriteriaFiles(hotelCriteriaID, criteriaFileID) {
            ko.contextFor(document.getElementById("container")).$data.fetchHotelCriteriaFiles(hotelCriteriaID, criteriaFileID);
        }
    </script>


</body>
</html>
