@{
    ViewBag.Title = "Ξεχάσατε τον κωδικό σας";
    Layout = "~/Views/Shared/_AnonymousLayout.cshtml";
}

<div class="login-bg account-pages pt-2 pt-sm-5 pb-4 pb-sm-5 position-relative">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xxl-4 col-lg-5">
                <div class="card">
                    <div class="py-4 text-center login-info-panel">
                        <div>
                            <h3>Επαναφορά Κωδικού</h3>
                            <small>Σύστημα Περιβαλλοντικής Κατάταξης Τουριστικών Καταλυμάτων</small>
                        </div>
                    </div>

                    <div class="card-body p-4">
                        <div id="step-form">
                            <p class="text-muted">
                                Εισάγετε το email του λογαριασμού σας. Θα σας αποσταλεί σύνδεσμος
                                για τον ορισμό νέου κωδικού.
                            </p>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input class="form-control" type="email" id="email" placeholder="Το email σύνδεσής σας" autofocus />
                            </div>
                            <div id="msg" class="alert alert-danger d-none py-2"></div>
                            <div class="text-center">
                                <button class="btn login-info-panel" id="btn-submit">Αποστολή συνδέσμου</button>
                            </div>
                        </div>

                        <div id="step-done" class="text-center" style="display:none;">
                            <i class="mdi mdi-email-check-outline text-success" style="font-size:48px;"></i>
                            <p class="mt-2">
                                Αν το email αντιστοιχεί σε λογαριασμό επιθεωρητή, θα λάβετε σύντομα
                                μήνυμα με τον σύνδεσμο επαναφοράς. Ελέγξτε και τον φάκελο
                                ανεπιθύμητης αλληλογραφίας.
                            </p>
                        </div>

                        <div class="mt-3 text-center">
                            <a href=@Url.Action("Login", "Account") class="text-muted"><small><i class="mdi mdi-arrow-left"></i> Επιστροφή στη σύνδεση</small></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<footer class="footer footer-alt" style="color:white">
    <script>document.write(new Date().getFullYear())</script> © ΞΕΝΟΔΟΧΕΙΑΚΟ ΕΠΙΜΕΛΗΤΗΡΙΟ ΕΛΛΑΔΟΣ
</footer>

<script>
    (function () {
        var btn = document.getElementById("btn-submit"), msg = document.getElementById("msg");
        function submit() {
            var email = document.getElementById("email").value.trim();
            msg.classList.add("d-none");
            btn.disabled = true; btn.textContent = "Αποστολή...";
            fetch('@Url.Action("RecoverRequest", "Auth")', {
                method: "POST",
                headers: { "Content-Type": "application/x-www-form-urlencoded" },
                body: "email=" + encodeURIComponent(email)
            }).then(function (res) { return res.json(); }).then(function (r) {
                btn.disabled = false; btn.textContent = "Αποστολή συνδέσμου";
                if (r && r.success) {
                    document.getElementById("step-form").style.display = "none";
                    document.getElementById("step-done").style.display = "block";
                } else { msg.classList.remove("d-none"); msg.textContent = (r && r.message) || "Παρουσιάστηκε σφάλμα."; }
            }).catch(function () {
                btn.disabled = false; btn.textContent = "Αποστολή συνδέσμου";
                msg.classList.remove("d-none"); msg.textContent = "Σφάλμα επικοινωνίας.";
            });
        }
        btn.addEventListener("click", submit);
        document.getElementById("email").addEventListener("keypress", function (e) { if (e.key === "Enter") submit(); });
    })();
</script>
