@{
    ViewBag.Title = "Βαθμίδες & Βάσεις";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="medals-saved-toast" style="display:none; position:fixed; top:70px; right:20px; z-index:4000;"
     class="alert alert-success shadow"><i class="uil uil-check-circle me-1"></i>Αποθηκεύτηκε</div>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="javascript: void(0);">Αρχική</a></li>
                    <li class="breadcrumb-item active">Βαθμίδες & Βάσεις</li>
                </ol>
            </div>
            <h4 class="page-title">Διαχείριση Βαθμίδων</h4>
        </div>
    </div>
</div>

<!-- ════ Όρια συνολικής βαθμολογίας ανά μετάλιο (TEE_Medals) ════ -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header py-2 d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0"><i class="uil uil-award me-1"></i> Συνολική Βαθμολογία ανά Μετάλιο</h5>
                <button class="btn btn-sm btn-success" data-bind="click: saveMedals">
                    <i class="uil uil-save me-1"></i>Αποθήκευση Ορίων
                </button>
            </div>
            <div class="card-body py-2">
                <p class="text-muted mb-2"><small>Ορίστε το εύρος της συνολικής (αναγμένης, 0–95) βαθμολογίας για κάθε μετάλιο.</small></p>
                <div class="table-responsive">
                    <table class="table table-bordered table-sm align-middle mb-0" style="max-width:560px;">
                        <thead class="table-light">
                            <tr>
                                <th>Μετάλιο</th>
                                <th class="text-center" style="width:130px;">Από (≥)</th>
                                <th class="text-center" style="width:130px;">Έως (&lt;)</th>
                            </tr>
                        </thead>
                        <tbody data-bind="foreach: medalsEdit">
                            <tr>
                                <td><input type="text" class="form-control form-control-sm" data-bind="value: title" /></td>
                                <td><input type="number" step="0.01" class="form-control form-control-sm text-end" data-bind="value: min" /></td>
                                <td><input type="number" step="0.01" class="form-control form-control-sm text-end" data-bind="value: max" /></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ════ Ελάχιστες βάσεις ανά πυλώνα ════ -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header py-2">
                <h5 class="card-title mb-0"><i class="uil uil-layer-group me-1"></i> Ελάχιστες Βάσεις ανά Πυλώνα</h5>
            </div>
            <div class="card-body">

                <!-- Διακόπτης -->
                <div class="d-flex align-items-center justify-content-between border-bottom pb-2 mb-3">
                    <div>
                        <div class="form-check form-switch">
                            <input type="checkbox" class="form-check-input" id="use-pillar-switch" data-bind="checked: usePillarThresholds">
                            <label class="form-check-label" for="use-pillar-switch">
                                <strong>Εφαρμογή ελάχιστων βάσεων ανά πυλώνα</strong>
                            </label>
                        </div>
                        <small class="text-muted">Όταν είναι ανενεργό, το μετάλιο αποδίδεται μόνο βάσει της συνολικής βαθμολογίας.</small>
                    </div>
                    <button class="btn btn-success" data-bind="click: save">
                        <i class="uil uil-save me-1"></i>Αποθήκευση
                    </button>
                </div>

                <p class="text-muted"><small>
                    Για κάθε πυλώνα και μετάλιο ορίστε την ελάχιστη βάση. Κενό ή 0 = καμία απαίτηση.
                    Επιλέξτε <strong>%</strong> (ποσοστό του μέγιστου του πυλώνα) ή <strong>μόρ.</strong> (απόλυτος αριθμός στην αναγμένη κλίμακα).
                </small></p>

                <div class="table-responsive">
                    <table class="table table-bordered table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="min-width:220px;">Πυλώνας</th>
                                <!-- ko foreach: medals -->
                                <th class="text-center" data-bind="text: title"></th>
                                <!-- /ko -->
                            </tr>
                        </thead>
                        <tbody data-bind="foreach: pillars">
                            <tr>
                                <td>
                                    <strong data-bind="text: title"></strong><br />
                                    <small class="text-muted">μέγιστο: <span data-bind="text: totalUnits"></span> μόρια</small>
                                </td>
                                <!-- ko foreach: cells -->
                                <td>
                                    <div class="input-group input-group-sm">
                                        <input type="number" min="0" step="0.5" class="form-control text-end"
                                               data-bind="value: value, valueUpdate: 'input'" />
                                        <select class="form-select" style="max-width:70px;" data-bind="value: isPercent">
                                            <option value="true">%</option>
                                            <option value="false">μόρ.</option>
                                        </select>
                                    </div>
                                    <!-- ko if: requiredText() -->
                                    <small class="text-muted" data-bind="text: requiredText"></small>
                                    <!-- /ko -->
                                </td>
                                <!-- /ko -->
                            </tr>
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>
