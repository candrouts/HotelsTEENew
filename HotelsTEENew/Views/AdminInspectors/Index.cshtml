@{
    ViewBag.Title = "Μητρώο Επιθεωρητών";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="javascript: void(0);">Αρχική</a></li>
                    <li class="breadcrumb-item active">Επιθεωρητές</li>
                </ol>
            </div>
            <h4 class="page-title">
                Μητρώο Επιθεωρητών
                <span class="badge bg-secondary ms-1" data-bind="text: inspectors().length"></span>
            </h4>
        </div>
    </div>
</div>

<!-- ════ Φίλτρο αναζήτησης ════ -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body py-2">
                <div class="row g-2 align-items-center">
                    <div class="col-md-6">
                        <input type="text" class="form-control form-control-sm"
                               placeholder="Αναζήτηση: όνομα, email, ΑΦΜ, τηλέφωνο, περιοχή..."
                               data-bind="value: filterText, valueUpdate: 'input'" />
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-sm btn-light" data-bind="click: clearFilter">
                            <i class="uil uil-times me-1"></i>Καθαρισμός
                        </button>
                        <button class="btn btn-sm btn-info ms-1" data-bind="click: inviteAll, disable: inviteBusy"
                                title="Αποστολή πρόσκλησης ενεργοποίησης σε όλους τους επιθεωρητές χωρίς λογαριασμό">
                            <i class="uil-envelope-send me-1"></i>Πρόσκληση σε όλους χωρίς λογαριασμό
                        </button>
                        <span class="text-muted ms-2">
                            <span data-bind="text: filteredInspectors().length"></span> / <span data-bind="text: inspectors().length"></span>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ════ Λίστα επιθεωρητών ════ -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-centered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Επιθεωρητής</th>
                                <th>Επικοινωνία</th>
                                <th>Περιοχές δραστηριότητας</th>
                                <th style="width:110px;">Λογαριασμός</th>
                                <th style="width:230px;">Ενέργειες</th>
                            </tr>
                        </thead>
                        <tbody data-bind="foreach: filteredInspectors">
                            <tr>
                                <td>
                                    <strong data-bind="text: lastName + ' ' + firstName"></strong>
                                    <!-- ko if: taxNumber -->
                                    <br /><small class="text-muted">ΑΦΜ: <span data-bind="text: taxNumber"></span></small>
                                    <!-- /ko -->
                                </td>
                                <td>
                                    <span data-bind="text: email"></span><br />
                                    <small class="text-muted" data-bind="text: phone"></small>
                                </td>
                                <td><small class="text-muted" data-bind="text: areas || '— Δεν έχουν οριστεί —'"></small></td>
                                <td>
                                    <!-- ko if: hasAccount -->
                                    <span class="badge bg-success-subtle text-success"><i class="mdi mdi-check"></i> Ενεργός</span>
                                    <!-- /ko -->
                                    <!-- ko ifnot: hasAccount -->
                                    <span class="badge bg-secondary-subtle text-secondary">Χωρίς</span>
                                    <!-- /ko -->
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary"
                                            data-bind="click: $root.openAreas">
                                        <i class="uil-map-marker me-1"></i>Περιοχές
                                    </button>
                                    <!-- ko ifnot: hasAccount -->
                                    <button class="btn btn-sm btn-outline-info"
                                            data-bind="click: $root.sendInvitation, disable: $root.inviteBusy"
                                            title="Αποστολή email με σύνδεσμο ενεργοποίησης λογαριασμού">
                                        <i class="uil-envelope-send me-1"></i>Πρόσκληση
                                    </button>
                                    <!-- /ko -->
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- ko if: filteredInspectors().length === 0 -->
                    <div class="text-center text-muted py-4">Δεν βρέθηκαν επιθεωρητές.</div>
                    <!-- /ko -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ════ Μαζική εισαγωγή CSV ════ -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="uil-file-upload me-1"></i> Μαζική Εισαγωγή από CSV</h5>
            </div>
            <div class="card-body py-2">
                <div class="row g-2 align-items-center">
                    <div class="col-md-5">
                        <input type="file" id="csv-file-input" class="form-control form-control-sm" accept=".csv,.txt" />
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-sm btn-primary" data-bind="click: importCsv">
                            <i class="uil-upload me-1"></i>Εισαγωγή
                        </button>
                    </div>
                    <div class="col-md-4 text-muted">
                        <small>
                            Στήλες: <code>Όνομα;Επώνυμο;Email;Τηλέφωνο;ΑΦΜ</code><br />
                            (διαχωριστικό <code>;</code> ή <code>,</code> — UTF-8)
                        </small>
                    </div>
                </div>

                <!-- Αποτέλεσμα εισαγωγής -->
                <!-- ko if: importResult() -->
                <div class="alert mt-2 mb-0 py-2" data-bind="css: importResult().success ? 'alert-success' : 'alert-danger'">
                    <span data-bind="text: importResult().message"></span>
                    <!-- ko if: importResult().errors && importResult().errors.length > 0 -->
                    <ul class="mb-0 mt-1" data-bind="foreach: importResult().errors">
                        <li><small data-bind="text: $data"></small></li>
                    </ul>
                    <!-- /ko -->
                </div>
                <!-- /ko -->
            </div>
        </div>
    </div>
</div>

<!-- ════ Modal: Περιοχές δραστηριότητας επιθεωρητή ════ -->
<div id="areas-modal" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="uil-map-marker me-1"></i>
                    Περιοχές: <span data-bind="text: areasInspectorName"></span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <!-- ko foreach: areasPerifereies -->
                <div class="card mb-1 border">
                    <div class="card-header py-2 d-flex justify-content-between align-items-center"
                         style="cursor:pointer;" data-bind="click: $root.toggleExpand">
                        <strong data-bind="text: title"></strong>
                        <div class="form-check form-switch" data-bind="click: function(d, e) { e.stopPropagation(); return true; }">
                            <input type="checkbox" class="form-check-input" data-bind="checked: coversAll" />
                            <label class="form-check-label"><small>Ολόκληρη η Περιφέρεια</small></label>
                        </div>
                    </div>
                    <!-- ko if: isExpanded -->
                    <div class="card-body py-2">
                        <div class="row">
                            <!-- ko foreach: pes -->
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input"
                                           data-bind="checked: isChecked, enable: !$parent.coversAll(), attr: { id: 'adm-pe-' + kalID }" />
                                    <label class="form-check-label" data-bind="text: title, attr: { 'for': 'adm-pe-' + kalID }"></label>
                                </div>
                            </div>
                            <!-- /ko -->
                        </div>
                    </div>
                    <!-- /ko -->
                </div>
                <!-- /ko -->

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Κλείσιμο</button>
                <button type="button" class="btn btn-success" data-bind="click: saveAreas">
                    <i class="uil-save me-1"></i>Αποθήκευση
                </button>
            </div>
        </div>
    </div>
</div>
