
@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_AnonymousLayout.cshtml";
}


<div class="login-bg account-pages pt-2 pt-sm-5 pb-4 pb-sm-5 position-relative">
    <div id="container" class="login-shell">
        <div class="card overflow-hidden mb-0">
            <div class="login-split">

                <!-- ═══ Αριστερό πάνελ: branding ═══ -->
                <div class="login-split-left login-info-panel">
                            <div class="p-4 p-lg-5 w-100 d-flex flex-column justify-content-between">
                                <div>
                                    <h3>Σύστημα Περιβαλλοντικής Κατάταξης Τουριστικών Καταλυμάτων</h3>
                                    <small>
                                        Με τη συνεργασία ΞΕΕ – ΤΕΕ<br>
                                        και την εποπτεία του Υπουργείου Τουρισμού
                                    </small>
                                </div>

                                <div class="login-features text-start mx-auto mt-4">
                                    <div><i class="mdi mdi-leaf-circle-outline"></i> Αυτοαξιολόγηση σε κριτήρια βιωσιμότητας</div>
                                    <div><i class="mdi mdi-clipboard-check-outline"></i> Επιθεώρηση από πιστοποιημένους επιθεωρητές</div>
                                    <div><i class="mdi mdi-certificate-outline"></i> Βεβαίωση τριετούς ισχύος με ανάρτηση στη Διαύγεια</div>
                                </div>

                                <div class="mt-4">
                                    <div class="login-medals">
                                        <span class="login-medal medal-bronze" title="Χάλκινο"></span>
                                        <span class="login-medal medal-silver" title="Ασημένιο"></span>
                                        <span class="login-medal medal-gold" title="Χρυσό"></span>
                                        <span class="login-medal medal-platinum" title="Πλατινένιο"></span>
                                    </div>
                                    <small class="d-block mt-1" style="opacity:.75;">Τέσσερις βαθμίδες περιβαλλοντικής κατάταξης</small>
                                </div>
                            </div>
                        </div>

                <!-- ═══ Δεξί πάνελ: φόρμα εισόδου ═══ -->
                <div class="login-split-right">
                    <div class="card-body p-4 p-lg-5">

                                <div class="text-center">
                                    <img src="~/Content/xee_logo_smaller.png" alt="ΞΕΕ" style="height:52px;" class="mb-2" />
                                    <h4 class="text-dark-50 pb-3 fw-bold">Είσοδος στο σύστημα</h4>
                                </div>

                                <!-- Μήνυμα σφάλματος -->
                                <!-- ko if: error -->
                                <div class="alert alert-danger d-flex align-items-center py-2">
                                    <i class="mdi mdi-alert-circle-outline me-1"></i>
                                    <span data-bind="text: errorMessage"></span>
                                </div>
                                <!-- /ko -->

                                <div class="mb-3">
                                    <label for="emailaddress" class="form-label">Όνομα Χρήστη</label>
                                    <input class="form-control" type="text" id="userName" required="" placeholder="Εισάγετε το όνομα χρήστη σας" data-bind="value:UserName,hasfocus: true, event: { 'keypress': onEnter }">
                                </div>

                                <div class="mb-3">
                                    <a href=@Url.Action("RecoverPassword", "Auth") class="text-muted float-end"><small>Ξεχάσατε τον κωδικό σας;</small></a>
                                    <label for="password" class="form-label">Κωδικός</label>
                                    <div class="input-group input-group-merge">
                                        <input type="password" id="password" class="form-control" placeholder="Εισάγετε τον κωδικό σας" data-bind="value: Password, event: { 'keypress': onEnter }">
                                        <div class="input-group-text" data-password="false">
                                            <span class="password-eye"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="checkbox-signin" data-bind="checked : rememberme">
                                        <label class="form-check-label" for="checkbox-signin">Να με θυμάσαι</label>
                                    </div>
                                </div>

                                <div class="mb-3 mb-0 text-center d-grid">
                                    <button class="btn login-info-panel" data-bind="click: submitLogin, disable: isLoading">
                                        <!-- ko if: isLoading -->
                                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Σύνδεση...
                                        <!-- /ko -->
                                        <!-- ko ifnot: isLoading -->
                                        Είσοδος
                                        <!-- /ko -->
                                    </button>
                                </div>

                                <hr class="my-3" />
                                <div class="text-center">
                                    <p class="text-muted mb-0">
                                        Είστε πιστοποιημένος επιθεωρητής χωρίς λογαριασμό;<br />
                                        <a href=@Url.Action("Register", "Auth") class="text-muted"><b>Ενεργοποιήστε τον λογαριασμό σας</b></a>
                                    </p>
                                </div>

                    </div>
                </div>

            </div> <!-- end login-split -->
        </div> <!-- end card -->
    </div><!-- end login-shell -->
</div><!-- end page -->

<footer class="footer footer-alt" style="color:white">
    <script>document.write(new Date().getFullYear())</script> © ΞΕΝΟΔΟΧΕΙΑΚΟ ΕΠΙΜΕΛΗΤΗΡΙΟ ΕΛΛΑΔΟΣ
</footer>
